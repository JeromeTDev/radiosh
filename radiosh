#!/usr/bin/env bash

# 1. Define Variables
BINARY_NAME="radiosh"
INSTALL_DIR="$HOME/.local/bin"
DEST="$INSTALL_DIR/$BINARY_NAME"

draw_box() {
  local msg=" 📻 Now Playing: $1 "
  local len=${#msg}
  local edge=$(printf '═%.0s' $(seq 1 $len))

  echo -e "\n\e[1;32m╔${edge}╗"
  echo -e "║${msg}║"
  echo -e "╚${edge}╝\e[0m\n"
}

# 2. Installation Logic
if [[ "$1" == "--install" ]]; then
  echo "Installing $BINARY_NAME..."

  # Create directory if it doesn't exist
  mkdir -p "$INSTALL_DIR"

  # $0 is the file itself, regardless of its current name
  if cp "$0" "$DEST"; then
    chmod +x "$DEST"
    echo "✅ Successfully copied to $DEST."

    # Check if in PATH (Shell-agnostic)
    if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
      echo "⚠️  NOTE: $INSTALL_DIR is not in your PATH yet."
      echo "Add this to your .bashrc or .config/fish/config.fish:"
      echo "  Bash/Zsh: export PATH=\"\$HOME/.local/bin:\$PATH\""
      echo "  Fish:     fish_add_path \$HOME/.local/bin"
    else
      echo "🚀 $BINARY_NAME is ready and found in your PATH!"
    fi
  else
    echo "❌ Error copying to $DEST"
    exit 1
  fi
  exit 0
fi

# 3. Check Dependencies
for tool in fzf mpv jq curl; do
  if ! command -v "$tool" &>/dev/null; then
    echo "Error: '$tool' is not installed. Please install it first."
    exit 1
  fi
done

FAVORITES_FILE="$HOME/.config/mpv/radio.m3u"
mkdir -p "$(dirname "$FAVORITES_FILE")"
touch "$FAVORITES_FILE"

# FZF Options (Vim-style Hjkl navigation)
FZF_OPTS=(
  --bind 'h:up,j:down,k:up,l:accept'
  --reverse
  --height 40%
  --ansi
)

# Initial fzf call: Favorites + "Online Search"
CHOICE=$( (
  cat "$FAVORITES_FILE"
  echo "__ONLINE_SEARCH__"
) | fzf --prompt="Select Station or Online Search: " "${FZF_OPTS[@]}")

# Exit if no choice made (ESC)
[ -z "$CHOICE" ] && exit 0

if [ "$CHOICE" == "__ONLINE_SEARCH__" ]; then
  read -rp "Search Query: " QUERY
  QUERY_ENC=$(echo "$QUERY" | jq -sRr @uri)

  CHOICE=$(curl -s "https://de1.api.radio-browser.info/json/stations/search?name=$QUERY_ENC&limit=20" |
    jq -r 'sort_by(.votes) | reverse | .[] | "\(.name) | \(.url)"' |
    fzf --prompt="Select Online Station: " "${FZF_OPTS[@]}")

  URL=$(echo "$CHOICE" | cut -d'|' -f2 | xargs)
  if [ -n "$URL" ]; then
    draw_box "$CHOICE" # Hier auch die Box anzeigen!
    mpv --no-video "$URL"

    read -rp "Add to favorites? (y/N) " RESP
    if [[ "$RESP" =~ ^[Yy]$ ]]; then
      grep -Fxq "$CHOICE" "$FAVORITES_FILE" || echo "$CHOICE" >>"$FAVORITES_FILE"
      echo "Added!"
    fi
  fi
else
  # Play favorite directly
  # WICHTIG: Hier müssen wir die URL erst aus CHOICE extrahieren!
  URL=$(echo "$CHOICE" | cut -d'|' -f2 | xargs)
  
  if [ -n "$URL" ]; then
    draw_box "$CHOICE"
    mpv --no-video "$URL"
  fi
fi

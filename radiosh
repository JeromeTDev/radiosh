#!/usr/bin/env bash

# 1. Define Variables
BINARY_NAME="radiosh"
INSTALL_DIR="$HOME/.local/bin"
DEST="$INSTALL_DIR/$BINARY_NAME"
DEPENDENCIES=(fzf mpv jq curl)

draw_box() {
  local msg="Now Playing: $1"
  local len=${#msg}
  local edge=$(printf '═%.0s' $(seq 1 $len))

  echo -e "\n\e[1;32m╔${edge}╗"
  echo -e "║${msg}║"
  echo -e "╚${edge}╝\e[0m\n"
}

get_missing_dependencies() {
  local missing=()
  local tool

  for tool in "${DEPENDENCIES[@]}"; do
    if ! command -v "$tool" &>/dev/null; then
      missing+=("$tool")
    fi
  done

  [ ${#missing[@]} -eq 0 ] && return 0

  printf '%s\n' "${missing[@]}"
}

print_dependency_help() {
  local missing=("$@")

  [ ${#missing[@]} -eq 0 ] && return 0

  echo "Missing dependencies: ${missing[*]}"
  echo

  if command -v apt-get &>/dev/null; then
    echo "Install on Debian/Ubuntu:"
    echo "  sudo apt-get install ${missing[*]}"
    return
  fi

  if command -v dnf &>/dev/null; then
    echo "Install on Fedora:"
    echo "  sudo dnf install ${missing[*]}"
    return
  fi

  if command -v pacman &>/dev/null; then
    echo "Install on Arch:"
    echo "  sudo pacman -S ${missing[*]}"
    return
  fi

  if command -v zypper &>/dev/null; then
    echo "Install on openSUSE:"
    echo "  sudo zypper install ${missing[*]}"
    return
  fi

  if command -v brew &>/dev/null; then
    echo "Install with Homebrew:"
    echo "  brew install ${missing[*]}"
    return
  fi

  echo "Install them with your system package manager and re-run radiosh."
}

install_dependencies() {
  local missing=("$@")

  [ ${#missing[@]} -eq 0 ] && return 0

  if command -v apt-get &>/dev/null; then
    sudo apt-get install "${missing[@]}"
    return
  fi

  if command -v dnf &>/dev/null; then
    sudo dnf install "${missing[@]}"
    return
  fi

  if command -v pacman &>/dev/null; then
    sudo pacman -S "${missing[@]}"
    return
  fi

  if command -v zypper &>/dev/null; then
    sudo zypper install "${missing[@]}"
    return
  fi

  if command -v brew &>/dev/null; then
    brew install "${missing[@]}"
    return
  fi

  echo "Could not determine a supported package manager."
  print_dependency_help "${missing[@]}"
  return 1
}

print_help() {
  cat <<EOF
Usage: $BINARY_NAME [option]

Options:
  --help          Show this help message
  --install       Validate dependencies and install radiosh to ~/.local/bin
  --install-deps  Install missing dependencies with a supported package manager

Without options, radiosh starts the interactive player.
EOF
}

require_dependencies() {
  mapfile -t missing < <(get_missing_dependencies)

  if [ ${#missing[@]} -gt 0 ]; then
    print_dependency_help "${missing[@]}"
    exit 1
  fi
}

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  print_help
  exit 0
fi

if [[ "$1" == "--install-deps" ]]; then
  mapfile -t missing < <(get_missing_dependencies)

  if [ ${#missing[@]} -eq 0 ]; then
    echo "All dependencies are already installed."
    exit 0
  fi

  echo "Installing missing dependencies: ${missing[*]}"
  install_dependencies "${missing[@]}"
  exit $?
fi

# 2. Installation Logic
if [[ "$1" == "--install" ]]; then
  mapfile -t missing < <(get_missing_dependencies)

  if [ ${#missing[@]} -gt 0 ]; then
    print_dependency_help "${missing[@]}"
    echo
    echo "Run '$0 --install-deps' to install them automatically first."
    exit 1
  fi

  echo "Installing $BINARY_NAME..."
  mkdir -p "$INSTALL_DIR"
  if cp "$0" "$DEST"; then
    chmod +x "$DEST"
    echo "✅ Successfully copied to $DEST."
    if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
      echo "⚠️  NOTE: $INSTALL_DIR is not in your PATH yet."
      echo "Add this to your .bashrc or .config/fish/config.fish:"
      echo "  Bash/Zsh: export PATH=\"\$HOME/.local/bin:\$PATH\""
      echo "  Fish:     fish_add_path \$HOME/.local/bin"
    else
      echo "🚀 $BINARY_NAME is ready!"
    fi
  else
    echo "❌ Error copying to $DEST"
    exit 1
  fi
  exit 0
fi

# 3. Check Dependencies
require_dependencies

FAVORITES_FILE="$HOME/.config/mpv/radio.m3u"
mkdir -p "$(dirname "$FAVORITES_FILE")"
touch "$FAVORITES_FILE"

FZF_OPTS=(
  --bind 'h:up,j:down,k:up,l:accept'
  --reverse
  --height 40%
  --ansi
)

# Main Menu
CHOICE=$( (
  cat "$FAVORITES_FILE"
  echo "__ONLINE_SEARCH__"
) | fzf --prompt="Select Station or Online Search: " "${FZF_OPTS[@]}")

[ -z "$CHOICE" ] && exit 0

if [ "$CHOICE" == "__ONLINE_SEARCH__" ]; then
  read -rp "Search Query: " QUERY
  QUERY_ENC=$(jq -rn --arg q "$QUERY" '$q | @uri')

  API_URL="https://de1.api.radio-browser.info/json/stations/search?name=$QUERY_ENC&limit=20"
  API_RESULT=$(curl -s --max-time 10 "$API_URL")

  if [ -z "$API_RESULT" ] || [ "$API_RESULT" = "[]" ]; then
    echo "Error: No results or API unreachable. Check your internet connection."
    exit 1
  fi

  CHOICE=$(echo "$API_RESULT" |
    jq -r 'sort_by(.votes) | reverse | .[] | "\(.name) | \(.url)"' |
    fzf --prompt="Select Online Station: " "${FZF_OPTS[@]}")

  NAME=$(echo "$CHOICE" | cut -d'|' -f1 | xargs)
  URL=$(echo "$CHOICE" | cut -d'|' -f2 | xargs)

  if [ -n "$URL" ]; then
    draw_box "$NAME"
    mpv --no-video --really-quiet --terminal=yes --term-playing-msg="🎵 Song: \${metadata/by-key/icy-title}" "$URL"

    read -rp "Add to favorites? (y/N) " RESP
    if [[ "$RESP" =~ ^[Yy]$ ]]; then
      grep -Fxq "$CHOICE" "$FAVORITES_FILE" || echo "$CHOICE" >>"$FAVORITES_FILE"
      echo "Added!"
    fi
  fi
else
  # Play favorite directly
  NAME=$(echo "$CHOICE" | cut -d'|' -f1 | xargs)
  URL=$(echo "$CHOICE" | cut -d'|' -f2 | xargs)

  if [ -n "$URL" ]; then
    draw_box "$NAME"
    mpv --no-video --really-quiet --terminal=yes --term-playing-msg="🎵 Song: \${metadata/by-key/icy-title}" "$URL"
  fi
fi

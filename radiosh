#!/usr/bin/env bash

BINARY_NAME="radiosh"
INSTALL_DIR="${RADIOSH_INSTALL_DIR:-$HOME/.local/bin}"
DEST="$INSTALL_DIR/$BINARY_NAME"
DEPENDENCIES=(fzf mpv jq curl)
API_URL="${RADIOSH_API_URL:-https://all.api.radio-browser.info/json/stations/search}"
FAVORITES_FILE="${RADIOSH_FAVORITES_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/mpv/radio.m3u}"

FZF_OPTS=(
  --bind 'h:up,j:down,k:up,l:accept'
  --reverse
  --height 40%
  --ansi
)

draw_box() {
  local msg=" Now Playing: $1 "
  local len=${#msg}
  local edge

  printf -v edge '%*s' "$len" ''
  edge=${edge// /═}
  printf '\n\033[1;32m╔%s╗\n║%s║\n╚%s╝\033[0m\n' "$edge" "$msg" "$edge"
}

get_missing_dependencies() {
  local missing=()
  local tool

  for tool in "${DEPENDENCIES[@]}"; do
    if ! command -v "$tool" &>/dev/null; then
      missing+=("$tool")
    fi
  done

  [ "${#missing[@]}" -eq 0 ] && return 0
  printf '%s\n' "${missing[@]}"
}

print_dependency_help() {
  local missing=("$@")

  [ "${#missing[@]}" -eq 0 ] && return 0

  echo "Missing dependencies: ${missing[*]}"
  echo

  if command -v apt-get &>/dev/null; then
    echo "Install on Debian/Ubuntu:"
    echo "  sudo apt-get install ${missing[*]}"
    return
  fi

  if command -v dnf &>/dev/null; then
    echo "Install on Fedora:"
    echo "  sudo dnf install ${missing[*]}"
    return
  fi

  if command -v pacman &>/dev/null; then
    echo "Install on Arch:"
    echo "  sudo pacman -S ${missing[*]}"
    return
  fi

  if command -v zypper &>/dev/null; then
    echo "Install on openSUSE:"
    echo "  sudo zypper install ${missing[*]}"
    return
  fi

  if command -v brew &>/dev/null; then
    echo "Install with Homebrew:"
    echo "  brew install ${missing[*]}"
    return
  fi

  echo "Install them with your system package manager and re-run radiosh."
}

install_dependencies() {
  local missing=("$@")

  [ "${#missing[@]}" -eq 0 ] && return 0

  if command -v apt-get &>/dev/null; then
    sudo apt-get install "${missing[@]}"
    return
  fi

  if command -v dnf &>/dev/null; then
    sudo dnf install "${missing[@]}"
    return
  fi

  if command -v pacman &>/dev/null; then
    sudo pacman -S "${missing[@]}"
    return
  fi

  if command -v zypper &>/dev/null; then
    sudo zypper install "${missing[@]}"
    return
  fi

  if command -v brew &>/dev/null; then
    brew install "${missing[@]}"
    return
  fi

  echo "Could not determine a supported package manager."
  print_dependency_help "${missing[@]}"
  return 1
}

print_help() {
  cat <<EOF
Usage: $BINARY_NAME [option]

Options:
  --help          Show this help message
  --install       Validate dependencies and install radiosh to $INSTALL_DIR
  --install-deps  Install missing dependencies with a supported package manager

Without options, radiosh starts the interactive player.
EOF
}

require_dependencies() {
  local missing=()
  local tool

  while IFS= read -r tool; do
    [ -n "$tool" ] && missing+=("$tool")
  done < <(get_missing_dependencies)

  if [ "${#missing[@]}" -gt 0 ]; then
    print_dependency_help "${missing[@]}"
    return 1
  fi
}

install_radiosh() {
  local missing=()
  local source_path
  local destination_path
  local tool

  while IFS= read -r tool; do
    [ -n "$tool" ] && missing+=("$tool")
  done < <(get_missing_dependencies)
  if [ "${#missing[@]}" -gt 0 ]; then
    print_dependency_help "${missing[@]}"
    echo
    echo "Run '$0 --install-deps' to install them automatically first."
    return 1
  fi

  mkdir -p "$INSTALL_DIR" || return 1
  source_path=$(realpath "$0" 2>/dev/null || printf '%s' "$0")
  destination_path=$(realpath "$DEST" 2>/dev/null || printf '%s' "$DEST")

  if [ "$source_path" = "$destination_path" ]; then
    echo "$BINARY_NAME is already installed at $DEST."
  else
    echo "Installing $BINARY_NAME..."
    if ! cp "$0" "$DEST" || ! chmod +x "$DEST"; then
      echo "❌ Error copying to $DEST"
      return 1
    fi
    echo "✅ Successfully copied to $DEST."
  fi

  if [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
    echo "⚠️  NOTE: $INSTALL_DIR is not in your PATH yet."
    echo "Add this to your shell configuration:"
    echo "  Bash/Zsh: export PATH=\"\$HOME/.local/bin:\$PATH\""
    echo "  Fish:     fish_add_path \$HOME/.local/bin"
  else
    echo "🚀 $BINARY_NAME is ready!"
  fi
}

# Convert both the historical "name | URL" format and the current tab-separated
# format to one internal representation. URLs may themselves contain pipes.
normalize_station_record() {
  local record=$1
  local name
  local url

  if [[ "$record" == *$'\t'* ]]; then
    name=${record%%$'\t'*}
    url=${record#*$'\t'}
  elif [[ "$record" == *' | '* ]]; then
    name=${record%%' | '*}
    url=${record#*' | '}
  else
    return 1
  fi

  [ -n "$name" ] && [ -n "$url" ] || return 1
  printf '%s\t%s\n' "$name" "$url"
}

list_favorites() {
  local record

  [ -f "$FAVORITES_FILE" ] || return 0
  while IFS= read -r record || [ -n "$record" ]; do
    [ -z "$record" ] && continue
    normalize_station_record "$record" || true
  done <"$FAVORITES_FILE"
}

favorite_exists() {
  local wanted_name=$1
  local wanted_url=$2
  local record
  local name
  local url

  while IFS= read -r record; do
    name=${record%%$'\t'*}
    url=${record#*$'\t'}
    if [ "$name" = "$wanted_name" ] && [ "$url" = "$wanted_url" ]; then
      return 0
    fi
  done < <(list_favorites)
  return 1
}

add_favorite() {
  local name=$1
  local url=$2

  if favorite_exists "$name" "$url"; then
    echo "Already in favorites."
    return 0
  fi

  mkdir -p "$(dirname "$FAVORITES_FILE")" || return 1
  printf '%s\t%s\n' "$name" "$url" >>"$FAVORITES_FILE"
  echo "Added!"
}

select_main_menu_item() {
  {
    list_favorites
    printf '%s\n' '__ONLINE_SEARCH__'
  } | fzf --prompt="Select Station or Online Search: " \
    --delimiter=$'\t' --with-nth=1 "${FZF_OPTS[@]}"
}

search_stations() {
  local query=$1
  local api_result

  if [ -z "${query//[[:space:]]/}" ]; then
    echo "Search cancelled: enter a non-empty query." >&2
    return 1
  fi

  if ! api_result=$(curl --fail --silent --show-error --max-time 10 --get \
    --data-urlencode "name=$query" --data 'limit=20' "$API_URL"); then
    echo "Error: Radio Browser could not be reached." >&2
    return 1
  fi

  if ! jq -e 'type == "array"' >/dev/null 2>&1 <<<"$api_result"; then
    echo "Error: Radio Browser returned an invalid response." >&2
    return 1
  fi

  if [ "$(jq 'length' <<<"$api_result")" -eq 0 ]; then
    echo "No stations found for '$query'." >&2
    return 1
  fi

  jq -r '
    sort_by(.votes // 0) | reverse | .[] |
    select((.name // "") != "" and ((.url_resolved // .url // "") != "")) |
    [.name, (.url_resolved // .url)] | @tsv
  ' <<<"$api_result" |
    fzf --prompt="Select Online Station: " \
      --delimiter=$'\t' --with-nth=1 "${FZF_OPTS[@]}"
}

prompt_to_add_favorite() {
  local name=$1
  local url=$2
  local response

  while true; do
    if ! read -rp "Add to favorites? (y/N) " response; then
      echo
      return 0
    fi

    case "$response" in
      [Yy] | [Yy][Ee][Ss])
        add_favorite "$name" "$url"
        return
        ;;
      '' | [Nn] | [Nn][Oo])
        return 0
        ;;
      *) echo "Please answer y or n." ;;
    esac
  done
}

play_station() {
  local record=$1
  local offer_favorite=${2:-false}
  local name=${record%%$'\t'*}
  local url=${record#*$'\t'}

  if [ -z "$name" ] || [ -z "$url" ] || [ "$name" = "$url" ]; then
    echo "Error: the selected station is missing a playable URL." >&2
    return 1
  fi

  draw_box "$name"
  # mpv expands this property expression; the shell must pass it literally.
  # shellcheck disable=SC2016
  if ! mpv --no-video --really-quiet --terminal=yes \
    --term-playing-msg='🎵 Song: ${metadata/by-key/icy-title}' -- "$url"; then
    echo "Error: mpv could not play '$name'." >&2
    return 1
  fi

  if [ "$offer_favorite" = true ]; then
    prompt_to_add_favorite "$name" "$url"
  fi
}

run_player() {
  local choice
  local query

  require_dependencies || return 1
  mkdir -p "$(dirname "$FAVORITES_FILE")" || return 1
  touch "$FAVORITES_FILE" || return 1

  choice=$(select_main_menu_item) || return 0
  [ -n "$choice" ] || return 0

  if [ "$choice" = "__ONLINE_SEARCH__" ]; then
    read -rp "Search Query: " query || return 0
    if ! choice=$(search_stations "$query"); then
      return 1
    fi
    [ -n "$choice" ] || return 0
    play_station "$choice" true
  else
    play_station "$choice"
  fi
}

main() {
  case "${1:-}" in
    '') run_player ;;
    --help | -h) print_help ;;
    --install-deps)
      local missing=()
      local tool
      while IFS= read -r tool; do
        [ -n "$tool" ] && missing+=("$tool")
      done < <(get_missing_dependencies)
      if [ "${#missing[@]}" -eq 0 ]; then
        echo "All dependencies are already installed."
      else
        echo "Installing missing dependencies: ${missing[*]}"
        install_dependencies "${missing[@]}"
      fi
      ;;
    --install) install_radiosh ;;
    *)
      echo "Unknown option: $1" >&2
      print_help >&2
      return 2
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
